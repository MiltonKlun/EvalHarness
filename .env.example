# --- Generator (system under test): Google Gemini via AI Studio free tier ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Judge (evaluator): Anthropic Claude ---
# https://console.anthropic.com/ -> API keys
ANTHROPIC_API_KEY=

# --- Tracing (optional but recommended): LangSmith ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=llm-test-harness

# --- Record/replay switch ---
# 0 (default) = replay recorded LLM responses from evals/cache, hard-fail on a miss.
# 1           = make real API calls AND record them. Use locally / in the live CI tier.
LIVE_LLM=0
